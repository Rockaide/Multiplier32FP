	} ]
set id [waveform add -signals  {
	simulator::multiplier32FP_tb.dut.i_post_norm_mul:s_shr3
	} ]
set id [waveform add -signals  {
	simulator::multiplier32FP_tb.dut.i_post_norm_mul:s_sign_i
	} ]
set id [waveform add -signals  {
	simulator::multiplier32FP_tb.dut.i_post_norm_mul:s_sticky
	} ]
set id [waveform add -signals  {
	simulator::multiplier32FP_tb.dut.i_post_norm_mul:s_zeros
	} ]
set id [waveform add -signals  {
	simulator::multiplier32FP_tb.dut.i_post_norm_mul:sign_i
	} ]
set id [waveform add -cdivider divider]
set id [waveform add -signals  {
	simulator::multiplier32FP_tb.dut.i_pre_norm_mul:clk_i
	} ]
set id [waveform add -signals  {
