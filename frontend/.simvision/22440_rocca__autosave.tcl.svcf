	simulator::multiplier32FP_tb.dut.i_post_norm_mul:s_output_o
	} ]
waveform hierarchy collapse $id
set id [waveform add -signals  {
	simulator::multiplier32FP_tb.dut.i_post_norm_mul:s_overflow
	} ]
set id [waveform add -signals  {
	simulator::multiplier32FP_tb.dut.i_post_norm_mul:s_r_zeros
	} ]
set id [waveform add -signals  {
	simulator::multiplier32FP_tb.dut.i_post_norm_mul:s_rmode_i
	} ]
set id [waveform add -signals  {
	simulator::multiplier32FP_tb.dut.i_post_norm_mul:s_round
	} ]
set id [waveform add -signals  {
	simulator::multiplier32FP_tb.dut.i_post_norm_mul:s_roundup
	} ]
set id [waveform add -signals  {
